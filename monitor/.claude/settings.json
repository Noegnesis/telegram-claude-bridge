{
  "enabledPlugins": {
    "telegram@claude-plugins-official": false
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion|EnterPlanMode|ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-pane-only-tools.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/ensure-outbound.sh"
          }
        ]
      }
    ]
  }
}
